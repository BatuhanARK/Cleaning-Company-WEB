# Bu değerler artık frontend'de DEĞİL, sadece Vercel projesinin
# Environment Variables ekranında tanımlanacak (Settings > Environment Variables).
# Yerelde test etmek için `vercel dev` kullanıyorsan bu dosyayı .env olarak kopyalayabilirsin.

# Resend (https://resend.com) hesabından alınan API key
RESEND_API_KEY=

# Randevu taleplerinin gideceği şirket e-posta adresi
BOOKING_TO_EMAIL=

# Gönderen adres. Kendi domainini Resend'de doğrulamadan önce
# onboarding@resend.dev kullanılabilir (Resend hesabına giriş yapan
# adrese teslim edilir). Domain doğrulandıktan sonra örn:
# BOOKING_FROM_EMAIL=randevu@seninsiten.com
BOOKING_FROM_EMAIL=onboarding@resend.dev

# (opsiyonel) CORS için sitenin kendi domaini, boş bırakılırsa * kullanılır
ALLOWED_ORIGIN=
